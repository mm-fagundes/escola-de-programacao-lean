      "type": "text",
      "x": -1023.077248830604,
      "y": 1518.67000060515,
      "width": 567.6987829054381,
      "height": 83.45419602934787,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
