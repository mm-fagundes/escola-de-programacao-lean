    {
      "id": "pHmhXTWgtEoNN7tpQK6bc",
      "type": "text",
      "x": 2899.140875335566,
      "y": 1660.7761280102961,
      "width": 353.3671875,
      "height": 32.41164615946832,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
