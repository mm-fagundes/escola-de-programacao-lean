      "locked": false,
      "text": "Como isso é feito na computação:",
      "fontSize": 20.46030742596536,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Como isso é feito na computação:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rfnD0JOxFY5VIIB8l2pBg",
      "type": "text",
      "x": 1701.9799253162369,
      "y": 1898.7423619072188,
      "width": 333.8770668235622,
      "height": 434.78153280176383,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0z",
      "roundness": null,
      "seed": 1839691101,
      "version": 2568,
      "versionNonce": 367285811,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776048250919,
      "link": null,
      "locked": false,
      "text": "pegar pó_café;\npegar garrafa;\nabrir garrafa;\ncolocar filtro na garra;\ndespejar pó_cafe no filtro;\n\niniciar aquecimento da água;\n\nse temperatura da água for < 90:\n    continuar aquecimento;\nse não:\n    encerrar aquecimento;\n    despejar água sobre o filtro;\n    aguardar 20 minutos;\n    remover filtro;\n    virar café pronto na xícara;\n",
      "fontSize": 20.460307425965357,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "pegar pó_café;\npegar garrafa;\nabrir garrafa;\ncolocar filtro na garra;\ndespejar pó_cafe no filtro;\n\niniciar aquecimento da água;\n\nse temperatura da água for < 90:\n    continuar aquecimento;\nse não:\n    encerrar aquecimento;\n    despejar água sobre o filtro;\n    aguardar 20 minutos;\n    remover filtro;\n    virar café pronto na xícara;\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
