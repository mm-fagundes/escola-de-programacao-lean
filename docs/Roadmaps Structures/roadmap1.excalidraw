      "isDeleted": false,
      "boundElements": [],
      "updated": 1776048250919,
      "link": null,
      "locked": false,
      "text": "O que é abstrair?",
      "fontSize": 25.75870241147938,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "O que é abstrair?",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "kG-Y84goYvD2oKj1g5Ftv",
      "type": "text",
      "x": 721.5542781508238,
      "y": 1321.083070309195,
      "width": 676.1756541385104,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ay",
      "roundness": null,
      "seed": 148010163,
      "version": 3434,
      "versionNonce": 731169523,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776048250919,
      "link": null,
      "locked": false,
      "text": "Abstrair é filtrar a complexidade desnecessária de acordo com o\ncontexto. Em um carro, por exemplo, o motorista não precisa\nentender o funcionamento dos pistões ou do sistema de freios; ele\nsó precisa de uma interface simples e intuitiva. Assim, os pedais\noperam como a abstração de toda a engenharia mecânica sob o capô.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Abstrair é filtrar a complexidade desnecessária de acordo com o contexto. Em um carro, por exemplo, o motorista não precisa entender o funcionamento dos pistões ou do sistema de freios; ele só precisa de uma interface simples e intuitiva. Assim, os pedais operam como a abstração de toda a engenharia mecânica sob o capô.",
      "autoResize": false,
      "lineHeight": 1.25
    },
