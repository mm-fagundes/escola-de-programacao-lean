      "isDeleted": false,
      "boundElements": [],
      "updated": 1776048250920,
      "link": null,
      "locked": false,
      "text": "Para evitar repetições, transformamos padrões frequentes em funções. Isso\npermite reutilizar um algoritmo inteiro apenas chamando o seu nome, tornando o\ncódigo muito mais organizado.",
      "fontSize": 21.57329209218931,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Para evitar repetições, transformamos padrões frequentes em funções. Isso permite reutilizar um algoritmo inteiro apenas chamando o seu nome, tornando o código muito mais organizado.",
      "autoResize": false,
      "lineHeight": 1.25
    },
